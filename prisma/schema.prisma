// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(uuid(7))
  name           String
  email          String
  emailVerified  Boolean   @default(false)
  githubUsername String    @unique
  githubId       Int       @unique
  image          String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sessions       Session[]
  accounts       Account[]

  githubStats    GithubStats?
  statsSnapshots GithubStatsSnapshot[]
  blogPosts      BlogPost[]

  role       String?
  banned     Boolean   @default(false)
  banReason  String?
  banExpires DateTime?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(uuid(7))
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid(7))
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@index([accountId, providerId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid(7))
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model RateLimit {
  id          String @id @default(uuid(7))
  key         String
  count       Int
  lastRequest BigInt

  @@unique([key])
  @@map("rate_limit")
}

model GithubStats {
  id            String   @id @default(uuid(7))
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commits       Int      @default(0)
  pullRequests  Int      @default(0)
  repositories  Int      @default(0)
  contributions Int      @default(0)
  followers     Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@index([commits(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
  @@map("github_stats")
}

model GithubStatsSnapshot {
  id           String         @id @default(uuid(7))
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  period       SnapshotPeriod
  periodKey    String
  commits      Int            @default(0)
  pullRequests Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([userId, period, periodKey])
  @@index([period, periodKey, commits(sort: Desc)])
  @@index([period, commits(sort: Desc)])
  @@map("github_stats_snapshot")
}

enum SnapshotPeriod {
  WEEKLY
  MONTHLY
}

model ShowcaseProject {
  id            String   @id @default(uuid(7))
  repo          String   @unique
  submittedBy   String
  banner        String?
  links         String[]
  website       String?
  createdAt     DateTime @default(now())
  stars         Int      @default(0)
  forks         Int      @default(0)
  openIssues    Int      @default(0)
  openPRs       Int      @default(0)
  description   String?
  homepageUrl   String?
  license       String?
  language      String?
  languageColor String?
  fileSha       String
  updatedAt     DateTime @updatedAt

  @@index([createdAt(sort: Desc)])
  @@map("showcase_project")
}

model BlogPost {
  id          String   @id @default(uuid(7))
  slug        String   @unique
  title       String
  description String
  tags        String[]
  coverImage  String
  userId      String
  contentMdx  String
  readingTime Int      @default(0)
  contentSha  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
  @@map("blog_post")
}
