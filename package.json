{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "prisma:generate": "prisma generate",
    "checks": "node scripts/pr-checks.ts",
    "lint": "eslint",
    "bootstrap": "pnpm i && pnpm install:skills && pnpm install:heroui_docs",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "install:skills": "pnpx skills@latest experimental_install",
    "install:heroui_docs": "pnpx heroui-cli@latest agents-md --react --output AGENTS.md"
  },
  "dependencies": {
    "@better-auth/infra": "0.2.8",
    "@better-auth/prisma-adapter": "1.6.11",
    "@heroui/react": "3.0.5",
    "@heroui/styles": "3.0.5",
    "@mdx-js/mdx": "3.1.1",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@tailwindcss/typography": "0.5.19",
    "@types/mdx": "2.0.13",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "better-auth": "1.6.11",
    "dotenv": "17.4.2",
    "js-yaml": "4.1.1",
    "motion": "12.40.0",
    "next": "16.2.6",
    "nuqs": "2.8.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-icons": "5.6.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-pretty-code": "0.14.3",
    "rehype-slug": "6.0.0",
    "remark": "15.0.1",
    "remark-gfm": "4.0.1",
    "shiki": "4.1.0",
    "swr": "2.4.1",
    "unist-util-visit": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "postcss-load-config": "6.0.1",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3"
  }
}
